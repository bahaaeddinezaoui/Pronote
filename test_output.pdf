":"Failed to load student records","msg_error_searching":"Error searching student: ","no_records_period":"No records found in this period.","no_absences_period":"No absences recorded in this period.","no_observations_period":"No observations recorded in this period.","no_punishments_period":"No punishments found in this period.","no_rewards_period":"No rewards found in this period.","administrator":"Administrator","quick_actions":"Quick Actions","generate_report":"Generate Report","onboarding_welcome_title":"Welcome to eNote!","onboarding_welcome_desc":"To ensure you have the best experience, we need to complete a quick two-step setup for your account. This will allow you to manage your students and classroom activities efficiently.","onboarding_step1_title":"Update Security","onboarding_step1_desc":"Change your temporary password to a secure personal one.","onboarding_step2_title":"Classroom Assignment","onboarding_step2_desc":"Select the categories, sections, and majors you are responsible for.","onboarding_get_started":"Get Started","onboarding_select_categories":"Select categories, sections, and majors","onboarding_categories_label":"Categories","onboarding_select_majors":"Select Majors:","onboarding_select_sections_for_major":"Select Sections for each Major:","onboarding_selection_summary":"Selection Summary:","onboarding_summary_text":"You have selected %d major(s) across %d section(s).","onboarding_save":"Save","onboarding_saved_success":"Saved successfully.","onboarding_save_failed":"Save failed.","onboarding_select_at_least_one":"Please select at least one major and section.","onboarding_loading_categories":"Loading categories...","onboarding_failed_load_categories":"Failed to load categories","onboarding_no_categories":"No categories available","onboarding_error_loading_categories":"Error loading categories","onboarding_loading_majors":"Loading majors...","onboarding_failed_load_majors":"Failed to load majors","onboarding_no_majors":"No majors available","onboarding_error_loading_majors":"Error loading majors","onboarding_sections_for":"Sections for %s:","onboarding_loading_sections":"Loading sections...","onboarding_failed_load_sections":"Failed to load sections","onboarding_no_sections":"No sections available for this category","onboarding_error_loading_sections":"Error loading sections","onboarding_select_all_majors":"Select All Majors","onboarding_clear_all_majors":"Clear All Majors","onboarding_select_all":"Select All","onboarding_clear_all":"Clear All","onboarding_password_updated":"Password updated.","onboarding_major_fallback":"Major","tutorial_close":"Close","tutorial_skip":"Skip","tutorial_prev":"Back","tutorial_next":"Next","tutorial_finish":"Finish","tutorial_done_toast":"Tutorial completed!","tutorial_step_home_title":"Home","tutorial_step_home_body":"Use this to go back to your main dashboard.","tutorial_intro_title":"Welcome to eNote","tutorial_intro_body":"This tour will guide you through the main areas of the application. Use Next\/Back to navigate, Skip to stop, and you can restart this tour anytime from the sidebar.","tutorial_outro_title":"You are ready!","tutorial_outro_body":"If you forget something, click \u201cTutorial\u201d in the sidebar to replay this guide.","tutorial_step_sidebar_title":"Sidebar navigation","tutorial_step_sidebar_body":"The sidebar is the main navigation. The highlighted item shows where you are. Use it to switch between features.","tutorial_step_language_title":"Language","tutorial_step_language_body":"Switch between English and Arabic. The whole interface will adapt (including right-to-left layout).","tutorial_step_logout_title":"Logout","tutorial_step_logout_body":"Log out when you finish using the system, especially on shared computers.","tutorial_step_admin_notifications_title":"Notifications","tutorial_step_admin_notifications_body":"New teacher observations appear here as notifications. Click the bell to open the panel and review new items.","tutorial_step_admin_welcome_title":"Dashboard overview","tutorial_step_admin_welcome_body":"This page gives you an overview of activity across the institution.","tutorial_step_admin_stats_title":"Statistics","tutorial_step_admin_stats_body":"These cards show key totals like students, teachers, sessions, absences, and observations.","tutorial_step_admin_recent_title":"Recent activity","tutorial_step_admin_recent_body":"Review the latest observations\/absences to follow up quickly and spot patterns.","tutorial_step_teacher_hero_title":"Your home","tutorial_step_teacher_hero_body":"This is your starting point. From here you can jump quickly to your daily tasks.","tutorial_step_teacher_obs_card_title":"Observations summary","tutorial_step_teacher_obs_card_body":"See how many observations you have recorded and use the shortcut to add a new one.","tutorial_step_teacher_majors_card_title":"Your majors","tutorial_step_teacher_majors_card_body":"This card shows the majors assigned to you, plus a shortcut to start attendance.","tutorial_step_secretary_welcome_title":"Secretary dashboard","tutorial_step_secretary_welcome_body":"This page shows quick stats and helps you access common tasks faster.","tutorial_step_secretary_actions_title":"Quick actions","tutorial_step_secretary_actions_body":"Use these shortcuts to start registering a new student without searching through pages.","tutorial_step_search_title":"Search","tutorial_step_search_body":"Search study sessions by date and time slot.","tutorial_step_records_title":"Student Records","tutorial_step_records_body":"Search students and review their records.","tutorial_step_absences_title":"Absences","tutorial_step_absences_body":"Record attendance for your sessions.","tutorial_step_observations_title":"Observations","tutorial_step_observations_body":"Create observations for student performance.","tutorial_step_insert_student_title":"Insert Student","tutorial_step_insert_student_body":"Register new students using the form.","tutorial_step_profile_title":"Profile","tutorial_step_profile_body":"View your account information and access details.","tutorial_step_options_title":"Options","tutorial_step_options_body":"Change your password and adjust settings.","tutorial_step_restart_title":"Tutorial","tutorial_step_restart_body":"Restart this tutorial anytime from here.","try_demo":"Try Interactive Demo","tutorial_progress":"Complete all 5 steps to finish the tutorial","tutorial_complete":"Tutorial Complete!","demo_login_title":"Login Demo","step1_preview":"Click to learn about logging in","step2_preview":"Explore your personalized dashboard","step3_preview":"Manage student records","step4_preview":"Find what you need quickly","step5_preview":"Stay updated with notifications","check_username":"Enter your username","check_password":"Enter your secure password","check_role":"Select your role (Teacher\/Admin)","check_stats":"View key statistics","check_activities":"Review recent activities","check_navigation":"Navigate using the sidebar","check_observations":"Create observations","check_absences":"Record absences","check_student_info":"Update student information","check_search_student":"Search by student name","check_filter_date":"Filter by date range","check_filter_section":"Filter by section\/major","check_notifications":"View real-time notifications","check_profile":"Update your profile","check_ready":"Ready to get started!","try_it_now":"Try it now","explore_demo":"Explore demo","see_how":"See how it works","try_search":"Try search demo","get_started_now":"Get Started Now","upload_new_program_question":"Would you like to upload a new weekly program?","confirm_selections_title":"Confirm Selections","submit":"Submit","security":"Security","change_password_desc":"Update your account password to stay secure.","carousel_feature_students":"Student Management","carousel_feature_students_desc":"Efficiently manage student records, categories, and sections. Access comprehensive profiles with personal details, academic information, and attendance history.","carousel_feature_attendance":"Attendance Tracking","carousel_feature_attendance_desc":"Record and monitor student attendance with ease. Track absences, identify patterns, and generate detailed reports for better classroom management.","carousel_feature_reports":"Reports & Records","carousel_feature_reports_desc":"Access detailed student records and generate comprehensive reports. Search, filter, and export data for informed decision-making.","carousel_feature_notifications":"Real-Time Notifications","carousel_feature_notifications_desc":"Stay informed with instant alerts for new observations and important events. Never miss critical updates about your students.","edit_student":"Edit Student","edit_student_info":"Edit student information","student_not_found":"Student not found.","personal_details":"Personal Details","academic_info":"Academic Info","uniforms":"Uniforms","save_changes":"Save Changes","and":"&"};
        const loginForm = document.getElementById('login');
        const errorDiv = document.getElementById('login_error');

        loginForm.addEventListener('submit', function(e) {
            e.preventDefault();
            errorDiv.style.display = 'none';
            
            const formData = new FormData(loginForm);
            
            fetch('index.php', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    window.location.href = data.redirect;
                } else {
                    errorDiv.textContent = data.message;
                    errorDiv.style.display = 'block';
                }
            })
            .catch(err => {
                errorDiv.textContent = (T && T.error_unexpected) ? T.error_unexpected : 'An unexpected error occurred.';
                errorDiv.style.display = 'block';
            });
        });

        // Password toggle logic
        const togglePassword = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('password');

        togglePassword.addEventListener('click', function() {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            this.textContent = type === 'password' ? '👁️' : '🔒';
        });

        // If the user navigates back to this page while still logged in, bounce them home.
        window.addEventListener('pageshow', function () {
            fetch('session_status.php', { credentials: 'same-origin' })
                .then(res => res.json())
                .then(data => {
                    if (data.loggedIn && data.home) {
                        window.location.replace(data.home);
                    }
                })
                .catch(() => { /* ignore */ });
        });

        // Carousel functionality
        const slides = document.querySelectorAll('.carousel-slide');
        const dots = document.querySelectorAll('.carousel-dot');
        const prevBtn = document.querySelector('.carousel-prev');
        const nextBtn = document.querySelector('.carousel-next');
        let currentSlide = 0;
        let autoPlayInterval;

        function showSlide(index) {
            slides.forEach(slide => slide.classList.remove('active'));
            dots.forEach(dot => dot.classList.remove('active'));
            
            if (index >= slides.length) index = 0;
            if (index < 0) index = slides.length - 1;
            
            currentSlide = index;
            slides[currentSlide].classList.add('active');
            dots[currentSlide].classList.add('active');
        }

        function nextSlide() {
            showSlide(currentSlide + 1);
        }

        function prevSlide() {
            showSlide(currentSlide - 1);
        }

        function startAutoPlay() {
            autoPlayInterval = setInterval(nextSlide, 5000);
        }

        function stopAutoPlay() {
            clearInterval(autoPlayInterval);
        }

        prevBtn.addEventListener('click', () => {
            stopAutoPlay();
            prevSlide();
            startAutoPlay();
        });

        nextBtn.addEventListener('click', () => {
            stopAutoPlay();
            nextSlide();
            startAutoPlay();
        });

        dots.forEach((dot, index) => {
            dot.addEventListener('click', () => {
                stopAutoPlay();
                showSlide(index);
                startAutoPlay();
            });
        });

        // Start autoplay
        startAutoPlay();
    </script>
</body>
</html>

