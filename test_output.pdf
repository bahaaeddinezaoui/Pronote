<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <script>if(localStorage.getItem('edutrack_theme')==='dark') document.documentElement.setAttribute('data-theme', 'dark');</script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="styles.css" />
    <title>Login - eNote</title>
</head>
<body>
    <div class="login-wrapper">
        <!-- Left Side - Login Form -->
        <div class="login-left">
            <div class="login-lang-fix"><div class="lang-switcher-container">
    <a href="/login.php?lang=ar" class="lang-switch-btn">
        <span class="lang-icon">🌐</span>
        <span class="lang-label">العربية</span>
    </a>
</div>
</div>
            
            <div class="login-card">
                <div class="login-header">
                    <div class="login-logo">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        </svg>
                    </div>
                    <h1 class="login-title">Welcome to eNote!</h1>
                    <p class="login-subtitle">eNote</p>
                </div>

                <form action="index.php" method="post" id="login">
                    <div class="form-group">
                        <label class="form-label" for="username">Username:</label>
                        <input class="form-input" type="text" id="username" name="username" placeholder="Enter your username" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="password">Password:</label>
                        <div style="position: relative;">
                            <input class="form-input" type="password" id="password" name="password" placeholder="Enter your password" required style="padding-right: 40px;">
                            <span id="togglePassword" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); cursor: pointer; color: var(--text-secondary); user-select: none; font-size: 1.2rem;">
                                👁️
                            </span>
                        </div>
                    </div>

                    <button type="submit" id="login_button" class="btn btn-primary">Login</button>
                    <div id="login_error" class="alert alert-error mt-4" style="display: none; text-align: center;"></div>
                </form>
            </div>
        </div>

        <!-- Right Side - Feature Carousel -->
        <div class="login-right">
            <div class="carousel-container">
                <div class="carousel-slides">
                    <div class="carousel-slide active">
                        <div class="carousel-icon">
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                        </div>
                        <h2 class="carousel-title">Student Management</h2>
                        <p class="carousel-description">Efficiently manage student records, categories, and sections. Access comprehensive profiles with personal details, academic information, and attendance history.</p>
                    </div>
                    <div class="carousel-slide">
                        <div class="carousel-icon">
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                        </div>
                        <h2 class="carousel-title">Attendance Tracking</h2>
                        <p class="carousel-description">Record and monitor student attendance with ease. Track absences, identify patterns, and generate detailed reports for better classroom management.</p>
                    </div>
                    <div class="carousel-slide">
                        <div class="carousel-icon">
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                <polyline points="14 2 14 8 20 8"></polyline>
                                <line x1="16" y1="13" x2="8" y2="13"></line>
                                <line x1="16" y1="17" x2="8" y2="17"></line>
                                <polyline points="10 9 9 9 8 9"></polyline>
                            </svg>
                        </div>
                        <h2 class="carousel-title">Reports & Records</h2>
                        <p class="carousel-description">Access detailed student records and generate comprehensive reports. Search, filter, and export data for informed decision-making.</p>
                    </div>
                    <div class="carousel-slide">
                        <div class="carousel-icon">
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                            </svg>
                        </div>
                        <h2 class="carousel-title">Real-Time Notifications</h2>
                        <p class="carousel-description">Stay informed with instant alerts for new observations and important events. Never miss critical updates about your students.</p>
                    </div>
                </div>
                <div class="carousel-indicators">
                    <button class="carousel-dot active" data-slide="0"></button>
                    <button class="carousel-dot" data-slide="1"></button>
                    <button class="carousel-dot" data-slide="2"></button>
                    <button class="carousel-dot" data-slide="3"></button>
                </div>
                <div class="carousel-nav">
                    <button class="carousel-prev">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
